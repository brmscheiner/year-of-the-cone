---
import { getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { CharInfo } from '../components/CharInfo';
import { TripProgress } from '../components/TripProgress';
import { StatGrid } from '../components/StatGrid';
import { SocialFooter } from '../components/SocialFooter';
import { PineconeViewer } from '../components/PineconeViewer';
import { CurrentInventory } from '../components/CurrentInventory';

const general = await getEntry('general', 'config');
const counters = await getEntry('counters', 'index');
const inventory = await getEntry('inventory', 'index');

const {
  travelerName,
  title,
  tagline,
  startDate,
  currentLocation,
  currentCountry,
  socialLinks,
  coneCount = 0,
} = general.data;
const { items } = counters.data;
---

<BaseLayout title="Year Of The Cone">
  <main class="mx-auto max-w-5xl px-4 py-8">
    <div class="stone-panel overflow-hidden">
      {/* Status bar */}
      <div
        class="border-stone-groove text-parchment-dim flex items-center justify-between border-b px-6 py-2 text-sm"
      >
        <div class="flex items-center gap-3">
          <span class="glow-amber">⚔ ADVENTURER</span>
          <span>·</span>
          <span>{travelerName.toUpperCase()}</span>
        </div>
        <span class="blink glow-blood">● QUEST ACTIVE</span>
      </div>

      {/* Title */}
      <div class="border-stone-groove border-b px-6 py-8 text-center">
        <h1 class="glow-amber flicker font-pixel text-xl tracking-widest sm:text-2xl">
          {title}
        </h1>
        <p class="text-parchment-dim font-pixel mt-4 text-sm leading-loose tracking-widest">
          <a
            href="https://www.caseyclapp.com/yearofthecone"
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-parchment transition-colors hover:underline hover:underline-offset-4"
          >
            {tagline}
          </a>
        </p>
      </div>

      {/* Portrait + character stats */}
      <div class="border-stone-groove grid grid-cols-1 border-b md:grid-cols-[300px_1fr]">
        {/* Portrait */}
        <div
          class="border-stone-groove md:border-stone-groove flex items-center justify-center border-b py-4 md:border-r md:border-b-0"
        >
          <PineconeViewer client:load />
        </div>

        {/* Char info + progress */}
        <div class="flex flex-col">
          <div class="flex-1 px-8 py-6">
            <CharInfo
              travelerName={travelerName}
              location={currentLocation}
              country={currentCountry}
              startDate={startDate}
              client:only="react"
            />
          </div>
          <div class="border-stone-groove border-t px-8 py-6">
            <TripProgress coneCount={coneCount} client:only="react" />
          </div>
        </div>
      </div>

      {/* Codex */}
      <StatGrid items={items} client:load />

      {/* Inventory */}
      <CurrentInventory items={inventory.data.items} client:load />
    </div>
  </main>

  <SocialFooter links={socialLinks} client:load />
</BaseLayout>
